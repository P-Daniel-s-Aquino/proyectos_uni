	"toString format": {
		"prefix": "tosf",
		"body": [
			"@Override",
			"public String toString() {",
			"\treturn String.format(\"%n==============OBJETO==============%n\" +",
			"\t\t\"${1:MENSAJE}: %${2:TIPO}\", ${3:METODO()});",
			"}"
		],
		"description": "toString base con String.format"
	},
